{
  "name": "atrium-earth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node ./scripts/write-redirects.mjs",
    "preview": "astro preview",
    "data:smk": "node ./scripts/enrich-smk.mjs",
    "verify:assets": "node ./scripts/verify-catalog-assets.mjs",
    "audit:orientation": "node ./scripts/audit-model-orientation.mjs",
    "images:posters": "node ./scripts/generate-posters.mjs",
    "images:renders": "node ./scripts/render-thumbnails.mjs",
    "images:mark-renders": "node ./scripts/mark-rendered-slugs.mjs",
    "models:preview": ".venv/bin/python ./scripts/generate-previews.py",
    "import:catalog:legacy": "node ./scripts/import-catalog.mjs",
    "ingest": "node ./scripts/ingest-manifests.mjs",
    "ingest:discover": "node ./scripts/discover-sources.mjs",
    "ingest:fetch": "node ./scripts/fetch-source.mjs",
    "ingest:assemble": "node ./scripts/assemble-piece.mjs",
    "ingest:auto": "npm run ingest:discover && npm run ingest:fetch && npm run ingest:assemble"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.10",
    "playwright": "^1.61.1"
  },
  "dependencies": {
    "@google/model-viewer": "^4.2.0",
    "lucide": "^1.14.0",
    "three": "^0.182.0"
  }
}
